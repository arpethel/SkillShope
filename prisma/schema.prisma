generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio               String?
  isAdmin           Boolean   @default(false)
  publisherVerified Boolean   @default(false)
  githubUsername    String?
  stripeAccountId   String?
  accounts          Account[]
  sessions      Session[]
  skills        Skill[]
  reviews       Review[]
  purchases     Purchase[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Skill {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  longDescription String?
  category      String
  type          String   @default("skill") // skill | mcp-server | agent
  price         Float    @default(0)
  isFree        Boolean  @default(true)
  installCmd    String?
  sourceUrl         String   @default("")
  sourceType        String   @default("github") // github | npm | other
  sourceStatus      String   @default("pending") // pending | valid | invalid | error
  sourceCheckedAt   DateTime?
  downloads     Int      @default(0)
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  compatibility String   @default("claude-code") // comma-separated: claude-code,codex,cursor
  tags          String?  // comma-separated tags
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviews       Review[]
  purchases     Purchase[]
  files         SkillFile[]
  listingType     String   @default("original") // original | community
  originalAuthor  String?  // attribution for community skills
  originalUrl     String?  // canonical URL for community skills
  featured        Boolean  @default(false)
  verified        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId         String
  skill           Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  stripeSessionId String   @unique
  amount          Float
  createdAt       DateTime @default(now())

  downloadToken   DownloadToken?

  @@unique([userId, skillId])
}

model SkillFile {
  id        String @id @default(cuid())
  skillId   String
  skill     Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  filename  String
  content   String // file content (markdown, JSON, etc.)

  @@unique([skillId, filename])
}

model DownloadToken {
  id         String   @id @default(cuid())
  token      String   @unique
  purchaseId String   @unique
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
